# ===================================================
# .gitignore - NexaCorp Corporate Website
# ===================================================

# ---------- Build Output ----------
target/
build/
dist/
*.war
*.jar
*.class

# ---------- Maven ----------
.mvn/
mvnw
mvnw.cmd
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties

# ---------- IDE ----------
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
*.swp
*.swo
*~

# ---------- OS Files ----------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---------- Docker ----------
docker-compose.override.yml

# ---------- Node (if applicable) ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ---------- Environment ----------
.env
.env.local
.env.production
*.env

# ---------- Logs ----------
*.log
logs/

# ---------- Temp Files ----------
tmp/
temp/
*.tmp
*.bak
*.orig
